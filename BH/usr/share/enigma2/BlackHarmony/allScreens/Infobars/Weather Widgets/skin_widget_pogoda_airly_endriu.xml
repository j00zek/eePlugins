     </widget>
    <widget position="295,26" size="185,28" source="session.j00zekMSNWeather" render="j00zekLabel" font="HD_Thin; 20" foregroundColor="foreground" backgroundColor="black" halign="center" valign="center" noWrap="1" transparent="1" zPosition="10">
      <convert type="j00zekMSNWeather">RUN|['currentData']['pm25']['name']|-|['currentData']['pm25']['valInfo']</convert>
    </widget>
    <widget position="295,55" size="185,28" source="session.j00zekMSNWeather" render="j00zekLabel" font="HD_Thin; 20" foregroundColor="foreground" backgroundColor="black" halign="center" valign="center" noWrap="1" transparent="1" zPosition="10">
      <convert type="j00zekMSNWeather">RUN|['currentData']['pm10']['name']|-|['currentData']['pm10']['valInfo']</convert>
