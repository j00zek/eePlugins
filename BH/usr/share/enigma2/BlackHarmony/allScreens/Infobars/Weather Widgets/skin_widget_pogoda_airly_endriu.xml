      <convert type="j00zekMSNWeather">RUN|['currentData']['pm1']['name']|-|['currentData']['pm1']['valInfo']</convert>
    </widget>
	
	<widget position="20,115" size="900,70" source="session.j00zekMSNWeather" render="Label" font="Roboto_HD; 22" backgroundColor="black" halign="center" noWrap="1" transparent="1" zPosition="2">
      <convert type="j00zekMSNWeather">RUN|['currentData']['airlyIndex']['info']|,  |0x00e6ffe6|['currentData']['airlyIndex']['advice']</convert>
	</widget>
	
	<!--pogoda dalej-->
	
	<eLabel name="new eLabel" position="485,23" size="1,90" backgroundColor="blue" />
    
