	<widget backgroundColor="black" font="Roboto_HD; 22" foregroundColor="white" render="j00zekLabel" position="95,36" size="118,25" source="session.j00zekMSNWeather" zPosition="3" halign="left" transparent="1">
      <convert type="j00zekMSNWeather">RUN|['currentData']['wind_speed']['valInfo']</convert>
    </widget>
    <widget backgroundColor="black" font="Roboto_HD; 22" foregroundColor="white" render="Label" position="80,80" size="55,25" source="session.j00zekMSNWeather" zPosition="3" halign="right" transparent="1">
      <convert type="j00zekMSNWeather">RUN|['currentData']['humidity']['valInfo']</convert>
    </widget>
	
	<!--AIRLY-->
  
